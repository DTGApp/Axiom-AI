<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B14"
    android:fillViewport="true"
    android:scrollbars="none"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="0dp"
        android:paddingBottom="40dp">

        <!-- Page header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Axiom Intelligence"
                android:textSize="19sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.01" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#111D2A"
            android:layout_marginBottom="16dp" />

        <!-- BATTERY DOCTOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery Doctor"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#F9FAFB" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI diagnosis of battery health and drain"
                        android:textSize="12sp"
                        android:textColor="#9AAEB9"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvBatteryLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#00C8FF"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:background="@drawable/bg_badge" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#111D2A"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvBatteryDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap Diagnose to run an AI analysis of your battery health and app usage."
                android:textSize="14sp"
                android:textColor="#B0C4D9"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="10dp" />

            <ProgressBar
                android:id="@+id/batteryProgress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:indeterminate="true"
                android:progressTint="#00C8FF"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvTopDrainApp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#9AAEB9"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvScreenOn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#9AAEB9"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvPickups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#9AAEB9"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnRunBatteryDoctor"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="Diagnose Battery"
                android:textSize="15sp"
                android:textColor="#080B14"
                android:backgroundTint="#00C8FF"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- AXIOM NOTICED -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Axiom Noticed"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#F9FAFB" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weekly pattern analysis from your usage"
                    android:textSize="12sp"
                    android:textColor="#9AAEB9"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#111D2A"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvWeeklyInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No insight yet. Axiom analyses your patterns weekly."
                android:textSize="15sp"
                android:textColor="#D1D5DB"
                android:lineSpacingMultiplier="1.65"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvInsightDataPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#9AAEB9"
                android:lineSpacingMultiplier="1.6"
                android:fontFamily="monospace"
                android:background="@drawable/bg_code_block"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnRefreshInsight"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="Analyse Now"
                android:textSize="15sp"
                android:textColor="#00C8FF"
                android:backgroundTint="#0D1520"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- AUTO MODE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto Mode"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#F9FAFB" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Automatic sleep, commute and work profiles"
                    android:textSize="12sp"
                    android:textColor="#9AAEB9"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#111D2A"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvCurrentMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detecting…"
                android:textSize="17sp"
                android:textColor="#F9FAFB"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RECENT SWITCHES"
                android:textSize="11sp"
                android:textColor="#3F5975"
                android:letterSpacing="0.10"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvModeLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No switches yet."
                android:textSize="13sp"
                android:textColor="#9AAEB9"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="18dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#111D2A"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvModePrefsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="When a mode activates, ring volume:"
                android:textSize="13sp"
                android:textColor="#B0C4D9"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgModeVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp">

                <RadioButton
                    android:id="@+id/rbSilent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Silent"
                    android:textSize="13sp"
                    android:textColor="#E0E0E0"
                    android:buttonTint="#00E5FF" />

                <RadioButton
                    android:id="@+id/rbVibrate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Vibrate"
                    android:textSize="13sp"
                    android:textColor="#E0E0E0"
                    android:buttonTint="#00E5FF" />

                <RadioButton
                    android:id="@+id/rbLowVol"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Low volume"
                    android:textSize="13sp"
                    android:textColor="#E0E0E0"
                    android:buttonTint="#00E5FF" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#111D2A"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1">

                <Button
                    android:id="@+id/btnResetMode"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="0.48"
                    android:text="Reset Now"
                    android:textSize="14sp"
                    android:textColor="#B0C4D9"
                    android:backgroundTint="#0D1520"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnCancelToday"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="0.52"
                    android:text="⛔  Pause Today"
                    android:textSize="14sp"
                    android:textColor="#FCA5A5"
                    android:backgroundTint="#1F0D0D"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All analysis runs on your device · No data ever leaves your phone"
            android:textSize="12sp"
            android:textColor="#3F5975"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>